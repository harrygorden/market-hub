# Anvil Uplink Configuration
# Copy this file to .env and add your actual keys

# Your Anvil app's uplink key (get from Anvil IDE -> Settings -> Uplink)
ANVIL_UPLINK_KEY=your_uplink_key_here

# Optional: Discord webhook for notifications
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Optional: Set environment (development/production)
# ENVIRONMENT=development

# Optional: Enable debug mode (true/false)
DEBUG_MODE=false
